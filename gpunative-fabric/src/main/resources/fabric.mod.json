{
    "schemaVersion": 1,
    "id": "gpunative",
    "version": "${version}",
    "name": "GPU Native",
    "description": "A GPU-driven rendering pipeline mod for Minecraft",
    "authors": ["gpunative"],
    "contact": {},
    "license": "MIT",
    "icon": "assets/gpunative/icon.png",
    "environment": "client",
    "entrypoints": {
        "main": ["com.dslsdzc.gpunative.fabric.GpuNativeFabric"],
        "client": ["com.dslsdzc.gpunative.fabric.GpuNativeFabric"]
    },
    "mixins": ["gpunative-fabric.mixins.json"],
    "depends": {
        "fabricloader": ">=0.15.0",
